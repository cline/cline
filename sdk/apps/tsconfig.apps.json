				"../packages/enterprise/src/*",
				"../packages/enterprise/src/*/index.ts"
			],
			"@clinebot/llms": ["../packages/llms/src/index.ts"],
			"@clinebot/shared": ["../packages/shared/src/index.ts"],
			"@clinebot/shared/storage": ["../packages/shared/src/storage/index.ts"],
			"@clinebot/shared/db": ["../packages/shared/src/db/index.ts"],
