{
	"compilerOptions": {
		"paths": {
			"@clinebot/agents": ["../packages/agents/src/index.ts"],
			"@clinebot/agents/*": [
				"../packages/agents/src/*",
				"../packages/agents/src/*/index.ts"
			],
			"@clinebot/core": ["../packages/core/src/index.ts"],
			"@clinebot/core/*": [
				"../packages/core/src/*",
				"../packages/core/src/*/index.ts"
			],
			"@clinebot/core/telemetry": ["../packages/core/src/telemetry/index.ts"],
			"@clinebot/llms": ["../packages/llms/src/index.ts"],
			"@clinebot/rpc": ["../packages/rpc/src/index.ts"],
			"@clinebot/rpc/*": [
				"../packages/rpc/src/*",
				"../packages/rpc/src/*/index.ts"
			],
			"@clinebot/shared": ["../packages/shared/src/index.ts"],
			"@clinebot/shared/storage": ["../packages/shared/src/storage/index.ts"],
			"@clinebot/shared/db": ["../packages/shared/src/db/index.ts"],
			"@clinebot/shared/*": [
				"../packages/shared/src/*",
				"../packages/shared/src/*/index.ts"
			]
		}
	}
}
