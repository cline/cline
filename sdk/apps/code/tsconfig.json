{
	"compilerOptions": {
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"target": "ES6",
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./*"],
			"@clinebot/agents": ["../../packages/agents/src/index.ts"],
			"@clinebot/core": ["../../packages/core/src/index.ts"],
			"@clinebot/core/hub": ["../../packages/core/src/hub/index.ts"],
			"@clinebot/llms": ["../../packages/llms/src/index.ts"],
			"@clinebot/shared": ["../../packages/shared/src/index.ts"],
			"@clinebot/shared/storage": [
				"../../packages/shared/src/storage/index.ts"
			],
			"@clinebot/shared/db": ["../../packages/shared/src/db/index.ts"],
			"@clinebot/shared/*": [
				"../../packages/shared/src/*",
				"../../packages/shared/src/*/index.ts"
			]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
