{
	"name": "@clinebot/cli",
	"displayName": "clite",
	"version": "0.0.1",
	"description": "[EXPERIMENTAL] A lightweight Cline CLI built with the Cline SDKs",
	"type": "module",
	"publishConfig": {
		"access": "restricted"
	},
	"bin": {
		"clite": "dist/index.js"
	},
	"engines": {
		"node": ">=22"
	},
	"main": "dist/index.js",
	"exports": {
		".": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && bun run bun.mts",
		"build:binary": "bun build --compile ./src/index.ts --compile --outfile ./dist/cline",
		"build:tgz": "bun run build && bun pm pack --destination ./dist",
		"dev": "CLINE_BUILD_ENV=development bun --conditions=development ./src/index.ts",
		"clean": "rm -rf dist node_modules",
		"typecheck": "tsc --noEmit",
		"test": "bun run test:unit",
		"test:unit": "vitest run --config vitest.config.ts",
		"test:e2e": "vitest run --config vitest.e2e.config.ts",
		"test:e2e:interactive": "vitest run --config vitest.interactive.e2e.config.ts",
		"test:watch": "vitest --config vitest.config.ts",
		"test:e2e:cli:tui": "cd src/tests && tui-test",
		"release": "bun run build && bun publish --access restricted",
		"link": "bun unlink && bun link"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "^0.16.1",
		"@chat-adapter/discord": "^4.23.0",
		"@chat-adapter/gchat": "^4.23.0",
		"@chat-adapter/linear": "^4.23.0",
		"@chat-adapter/slack": "^4.23.0",
		"@chat-adapter/telegram": "^4.23.0",
		"@chat-adapter/whatsapp": "^4.23.0",
		"chat": "^4.23.0",
		"commander": "^14.0.3",
		"ink": "^6.8.0",
		"ink-spinner": "^5.0.0",
		"open": "^10.2.0",
		"pino": "^10.3.1",
		"react": "^19.2.4",
		"react-devtools-core": "^7.0.1",
		"yaml": "^2.8.2",
		"zod": "^4.1.11"
	},
	"license": "Apache-2.0",
	"devDependencies": {
		"@clinebot/core": "workspace:*",
		"@clinebot/enterprise": "workspace:*",
		"@clinebot/shared": "workspace:*",
		"@microsoft/tui-test": "^0.0.2",
		"@types/react": "19.2.14"
	}
}
