{
	"name": "@clinebot/cli",
	"displayName": "clite",
	"version": "0.0.0",
	"description": "[EXPERIMENTAL] A lightweight Cline CLI built with the Cline SDKs",
	"type": "module",
	"bin": {
		"clite": "dist/index.js"
	},
	"main": "dist/index.js",
	"exports": {
		".": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && bun run bun.mts",
		"build:binary": "bun build ./src/index.ts --compile --outfile ./dist/clite --external @anthropic-ai/vertex-sdk",
		"build:tgz": "bun run build && bun run pack prepare && npm pack --pack-destination dist && bun run pack restore",
		"dev": "bun ./src/index.ts",
		"clean": "rm -rf dist node_modules",
		"typecheck": "tsc --noEmit",
		"test": "bun run test:unit",
		"test:unit": "vitest run --config vitest.config.ts",
		"test:e2e": "vitest run --config vitest.e2e.config.ts",
		"test:e2e:interactive": "vitest run --config vitest.interactive.e2e.config.ts",
		"test:watch": "vitest --config vitest.config.ts",
		"test:e2e:cli:tui": "cd src/tests && tui-test",
		"pack": "bun ./scripts/deps.mts",
		"release": "bun run build && bun run pack prepare && npm publish --access public && bun run pack restore",
		"link": "bun unlink && bun link"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "^0.16.1",
		"@chat-adapter/gchat": "^4.20.2",
		"@chat-adapter/slack": "^4.20.2",
		"@chat-adapter/telegram": "^4.20.2",
		"@chat-adapter/whatsapp": "^4.20.2",
		"@clinebot/agents": "workspace:*",
		"@clinebot/core": "workspace:*",
		"@clinebot/llms": "workspace:*",
		"@clinebot/rpc": "workspace:*",
		"@clinebot/shared": "workspace:*",
		"better-sqlite3": "^11.10.0",
		"chat": "^4.20.2",
		"commander": "^14.0.3",
		"ink": "^6.8.0",
		"open": "^10.2.0",
		"pino": "^10.3.1",
		"react": "^19.2.4",
		"react-devtools-core": "^7.0.1",
		"yaml": "^2.8.2"
	},
	"license": "Apache-2.0",
	"devDependencies": {
		"@microsoft/tui-test": "^0.0.2",
		"@types/react": "19.2.14"
	}
}
