{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"customConditions": ["development"]
	},
	"include": ["**/*.ts", "**/*.tsx", "**/bun.mts"],
	"exclude": ["node_modules", "**/dist/**", "**/.next/**"]
}
