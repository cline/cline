{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"jsx": "react-jsx",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["bun", "node", "react", "react-dom"]
	},
	"include": [
		"scripts/**/*.ts",
		"src/**/*.ts",
		"src/**/*.tsx",
		"tests/**/*.ts",
		"tests/**/*.tsx"
	]
}
