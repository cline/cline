{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"jsx": "react-jsx",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"noEmit": false,
		"outDir": "dist/components",
		"rootDir": "components",
		"types": ["react", "react-dom"]
	},
	"include": ["components/**/*.ts", "components/**/*.tsx"],
	"exclude": ["components/**/*.stories.ts", "components/**/*.stories.tsx"]
}
