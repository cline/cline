{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"baseUrl": ".",
		"rootDir": "..",
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"paths": {
			"@clinebot/agents": ["../agents/src/index.ts"],
			"@clinebot/agents/*": ["../agents/src/*", "../agents/src/*/index.ts"],
			"@clinebot/llms": ["../llms/src/index.ts"],
			"@clinebot/shared": ["../shared/src/index.ts"],
			"@clinebot/shared/*": ["../shared/src/*", "../shared/src/*/index.ts"]
		}
	}
}
