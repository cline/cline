{
	"name": "@clinebot/llms",
	"version": "0.0.26",
	"description": "Config-driven SDK for selecting, extending, and instantiating LLM providers and models",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"browser": "./dist/index.browser.js",
			"react-server": "./dist/index.browser.js",
			"development": "./src/index.ts",
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./node": {
			"development": "./src/index.ts",
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./browser": {
			"development": "./src/index.browser.ts",
			"import": "./dist/index.browser.js",
			"types": "./dist/index.browser.d.ts"
		},
		"./models": {
			"browser": "./dist/models.browser.js",
			"react-server": "./dist/models.browser.js",
			"development": "./src/models.ts",
			"import": "./dist/models.js",
			"types": "./dist/models.d.ts"
		},
		"./providers": {
			"development": "./src/providers.ts",
			"import": "./dist/providers.js",
			"types": "./dist/providers.d.ts"
		},
		"./providers/browser": {
			"development": "./src/providers.browser.ts",
			"import": "./dist/providers.browser.js",
			"types": "./dist/providers.browser.d.ts"
		},
		"./runtime": {
			"development": "./src/runtime.ts",
			"import": "./dist/runtime.js",
			"types": "./dist/runtime.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun run bun.mts && bun tsc -p tsconfig.build.json",
		"typecheck": "bun tsc -p tsconfig.dev.json --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"clean": "rm -rf dist node_modules",
		"generate:models": "bun run scripts/generate-models.ts"
	},
	"peerDependenciesMeta": {
		"@aws-sdk/client-bedrock-runtime": {
			"optional": true
		}
	},
	"dependencies": {
		"@ai-sdk/amazon-bedrock": "^4.0.67",
		"@ai-sdk/google-vertex": "^4.0.74",
		"@ai-sdk/mistral": "^3.0.24",
		"@ai-sdk/openai-compatible": "^2.0.37",
		"@anthropic-ai/sdk": "^0.78.0",
		"@aws-sdk/credential-providers": "^3.922.0",
		"@clinebot/shared": "workspace:*",
		"@google/genai": "^1.43.0",
		"@streamparser/json": "^0.0.21",
		"ai": "^6.0.112",
		"ai-sdk-provider-claude-code": "^3.4.3",
		"ai-sdk-provider-codex-cli": "^1.1.0",
		"ai-sdk-provider-opencode-sdk": "^2.1.2",
		"dify-ai-provider": "^1.1.0",
		"nanoid": "^5.1.7",
		"openai": "^6.25.0",
		"zod": "^4.3.6"
	},
	"peerDependencies": {
		"@aws-sdk/client-bedrock-runtime": "^3.0.0"
	}
}
