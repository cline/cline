{
	"name": "@clinebot/scheduler",
	"version": "0.0.22",
	"description": "[INTERNAL] Scheduled runtime execution primitives for Cline RPC hosts",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"development": "./src/index.ts",
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun run bun.mts && bun tsc --emitDeclarationOnly",
		"clean": "rm -rf dist node_modules",
		"typecheck": "bun tsc -p tsconfig.dev.json --noEmit",
		"test": "vitest run --config vitest.config.ts",
		"test:watch": "vitest --config vitest.config.ts",
		"verify:routines": "bun run ./scripts/verify-routine-feature.ts"
	},
	"dependencies": {
		"@clinebot/shared": "workspace:*"
	},
	"internal": true
}
